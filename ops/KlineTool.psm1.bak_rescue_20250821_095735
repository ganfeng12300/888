    $ts = [int64]([int64]$k[6] / 1000)  # closeTime (秒)
    [pscustomobject]@{
      ts=$ts; symbol=$Symbol
      open=[double]$k[1]; high=[double]$k[2]; low=[double]$k[3]; close=[double]$k[4]
      volume=[double]$k[5]; quote_volume=[double]$k[7]; trade_count=[int]$k[8]
      taker_buy_base=[double]$k[9]; taker_buy_quote=[double]$k[10]
    }
  }
  ,$rows
}

function Write-KlinesCsv {
  param([string]$Root,[string]$Interval,[string]$Symbol,[object[]]$Rows,[int]$TfSec,[int64]$CutoffSec)
  if(-not $Rows -or $Rows.Count -eq 0){ return 0 }
  # 只收盘 + O/H/L/C 合法性
  $rows = $Rows | ? { $_.ts -le $CutoffSec -and $_.high -ge [Math]::Max($_.open,$_.close) -and $_.low -le [Math]::Min($_.open,$_.close) }
  if($rows.Count -eq 0){ return 0 }
  $dir = Join-Path $Root ("data\klines\{0}" -f $Interval); New-Item -ItemType Directory -Force -Path $dir | Out-Null
  $csv = Join-Path $dir ("{0}.csv" -f $Symbol); $tmp = $csv + ".tmp"

  $existing = @{}
  if(Test-Path $csv){ Import-Csv $csv | % { $existing[[int64]$_.ts] = $_ } }
  foreach($r in $rows){ $existing[[int64]$r.ts] = $r }
  $ordered = $existing.GetEnumerator() | Sort-Object Name | % { $_.Value }
  $ordered | Export-Csv -Path $tmp -NoTypeInformation -Encoding UTF8
  Move-Item $tmp $csv -Force
  return $rows.Count
}

function Invoke-Backfill {
  [CmdletBinding()]
  param(
    [string]$Root="D:\SQuant_Pro",
    [ValidateSet('5m','15m','1h','4h','1d')] [string[]]$Intervals=@('1h','15m','5m','4h','1d'),
    [string]$SymbolsFile = (Join-Path $Root "universe\active.txt"),
    [int]$SinceDays = 270
  )
  $symbols = Get-Content $SymbolsFile | ? { $_ -and $_.Trim() -ne "" } | % { $_.Trim().ToUpper() } | Select-Object -Unique
  foreach($iv in $Intervals){
    $tf = Get-TimeframeSec $iv
    $cut = Get-Cutoff $tf
    $lastOpen = Get-LastClosedOpenSec -TfSec $tf -CutoffSec $cut
    $startOpen = $lastOpen - ($SinceDays * 86400)
    Write-Host "== Backfill $iv cutoff=$cut lastOpen=$lastOpen fromOpen>=$startOpen symbols=$($symbols.Count)"
    foreach($sym in $symbols){
      $cursor = $startOpen; $batch=1000; $total=0
      while($cursor -le $lastOpen){
        $end = [int64][Math]::Min($cursor + $tf * ($batch-1), $lastOpen)
        $rows = Get-KlinesBatch -Symbol $sym -Interval $iv -StartOpenSec $cursor -EndOpenSec $end -Limit $batch
        $w = Write-KlinesCsv -Root $Root -Interval $iv -Symbol $sym -Rows $rows -TfSec $tf -CutoffSec $cut
        $total += $w; $cursor = $end + $tf; Start-Sleep -Milliseconds 300
      }
      Write-Host ("[OK] {0} {1} wrote={2}" -f $iv,$sym,$total)
    }
  }
}

