function Get-KlinesBatch {
  param([string]$Symbol,[string]$Interval,[int64]$StartOpenSec,[int64]$EndOpenSec,[int]$Limit=1000)
  $q = @{ symbol=$Symbol; interval=$Interval; startTime=($StartOpenSec*1000); endTime=($EndOpenSec*1000); limit=$Limit }
  $arr = Invoke-Binance -Path "/fapi/v1/klines" -Query $q
  $rows = foreach($k in $arr){
    $ts = [int64]([int64]$k[6] / 1000)  # closeTime (秒)
    [pscustomobject]@{
      ts=$ts; symbol=$Symbol
      open=[double]$k[1]; high=[double]$k[2]; low=[double]$k[3]; close=[double]$k[4]
      volume=[double]$k[5]; quote_volume=[double]$k[7]; trade_count=[int]$k[8]
      taker_buy_base=[double]$k[9]; taker_buy_quote=[double]$k[10]
    }
  }
  ,$rows
}

function Write-KlinesCsv {
  param([string]$Root,[string]$Interval,[string]$Symbol,[object[]]$Rows,[int]$TfSec,[int64]$CutoffSec)
  if(-not $Rows -or $Rows.Count -eq 0){ return 0 }
  # 只收盘 + O/H/L/C 合法性
  $rows = $Rows | ? { $_.ts -le $CutoffSec -and $_.high -ge [Math]::Max($_.open,$_.close) -and $_.low -le [Math]::Min($_.open,$_.close) }
  if($rows.Count -eq 0){ return 0 }
  $dir = Join-Path $Root ("data\klines\{0}" -f $Interval); New-Item -ItemType Directory -Force -Path $dir | Out-Null
  $csv = Join-Path $dir ("{0}.csv" -f $Symbol); $tmp = $csv + ".tmp"

  $existing = @{}
  if(Test-Path $csv){ Import-Csv $csv | % { $existing[[int64]$_.ts] = $_ } }
  foreach($r in $rows){ $existing[[int64]$r.ts] = $r }
  $ordered = $existing.GetEnumerator() | Sort-Object Name | % { $_.Value }
  $ordered | Export-Csv -Path $tmp -NoTypeInformation -Encoding UTF8
  Move-Item $tmp $csv -Force
  return $rows.Count
}

