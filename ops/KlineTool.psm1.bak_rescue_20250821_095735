  param([string]$Root="D:\SQuant_Pro",[ValidateSet('5m','15m','1h','4h','1d')] [string]$Interval,[string]$SymbolsFile = (Join-Path $Root "universe\active.txt"))
  $tf = Get-TimeframeSec $Interval; $cut = Get-Cutoff $tf
  $dir = Join-Path $Root ("data\klines\{0}" -f $Interval)
  $symbols = Get-Content $SymbolsFile | ? { $_ } | % { $_.Trim().ToUpper() } | Select-Object -Unique
  $gapRows = @(); $covRows = @()
  foreach($sym in $symbols){
    $csv = Join-Path $dir ("{0}.csv" -f $sym)
    if(-not (Test-Path $csv)){ $covRows += [pscustomobject]@{symbol=$sym; expected=0; actual=0; ratio=0}; continue }
    $data = Import-Csv $csv | % { [int64]$_.ts } | Sort-Object
    if($data.Count -eq 0){ $covRows += [pscustomobject]@{symbol=$sym; expected=0; actual=0; ratio=0}; continue }
    $firstClose=$data[0]; $firstOpen=$firstClose-($tf-1)
    $firstAlignedOpen=[int64]([math]::Floor($firstOpen / $tf) * $tf)
    $firstAlignedClose=$firstAlignedOpen + $tf - 1
    $lastOpen = Get-LastClosedOpenSec -TfSec $tf -CutoffSec $cut
    $lastClose= $lastOpen + $tf - 1
    $expectedSet = New-Object System.Collections.Generic.HashSet[int64]
    for($t=$firstAlignedClose; $t -le $lastClose; $t += $tf){ [void]$expectedSet.Add($t) }
    $actualSet = New-Object System.Collections.Generic.HashSet[int64]
    foreach($t in $data){ if($t -le $cut){ [void]$actualSet.Add($t) } }
    $miss = New-Object System.Collections.Generic.List[int64]
    foreach($t in $expectedSet){ if(-not $actualSet.Contains($t)){ [void]$miss.Add($t) } }
    $miss = $miss | Sort-Object
    $i=0; while($i -lt $miss.Count){
      $start=$miss[$i]; $j=$i; while($j+1 -lt $miss.Count -and $miss[$j+1] -eq $miss[$j] + $tf){ $j++ }
      $end=$miss[$j]
      $gapRows += [pscustomobject]@{symbol=$sym; tf=$Interval; ts_missing_start=$start; ts_missing_end=$end; missing_n=[int](($end-$start)/$tf + 1)}
      $i = $j + 1
    }
    $covRows += [pscustomobject]@{symbol=$sym; expected=$expectedSet.Count; actual=$actualSet.Count; ratio=("{0:N4}" -f ($(if($expectedSet.Count -eq 0){1}else{$actualSet.Count/$expectedSet.Count})))}
  }
  $day = (Get-Date).ToString("yyyyMMdd_HHmmss")
  $outDir = Join-Path $Root ("data\gap_report\{0}" -f $day); New-Item -ItemType Directory -Force -Path $outDir | Out-Null
  $gapRows | Export-Csv (Join-Path $outDir ("gaps_{0}.csv" -f $Interval)) -NoTypeInformation -Encoding UTF8
  $covRows | Export-Csv (Join-Path $outDir ("coverage_{0}.csv" -f $Interval)) -NoTypeInformation -Encoding UTF8
  Write-Host "[COVERAGE]" $Interval
  ($covRows | Sort-Object ratio | Select-Object -First 5) | Format-Table -AutoSize
  if($gapRows.Count -gt 0){ Write-Warning ("Gaps found: {0} rows (see {1})" -f $gapRows.Count, $outDir) } else { Write-Host "No gaps." }
}

